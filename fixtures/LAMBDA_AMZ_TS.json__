{
  "id": "LAMBDA_AMZ_TS",
  "title": "LambdaGeo Amazon Time Series",
  "description": "Série temporal de imagens LambdaGeo para a região amazônica (1997-2003).",
  "version": "2",
  "is_available": true,
  "category": "optical",
  "license": "proprietary",

  "extent": {
    "spatial": [[-180, -90, 180, 90]],
    "temporal": [["1997-01-01", "2003-12-31"]]
  },

  "bands": [
